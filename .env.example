# ─── Database ─────────────────────────────────────
DATABASE_URL=postgresql://recipeshare:recipeshare@localhost:5432/recipeshare

# ─── JWT ──────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-me
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-me
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# ─── Redis ────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── AWS S3 (optional — falls back to local uploads) ──
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=recipeshare-uploads
CLOUDFRONT_URL=

# ─── OAuth (optional) ────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── Email (optional — logs to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@recipeshare.app

# ─── Sentry (optional) ───────────────────────────
SENTRY_DSN=

# ─── Image Moderation (optional) ─────────────────
# Set to "aws" for AWS Rekognition, "google" for Vision API, or leave empty
IMAGE_MODERATION_PROVIDER=

# ─── Frontend ─────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_APP_NAME=RecipeShare
NEXT_PUBLIC_GA_ID=
